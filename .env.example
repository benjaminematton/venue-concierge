# Anthropic API key. Required to talk to the agent.
ANTHROPIC_API_KEY=

# Upstash Redis credentials. Required only when you want the per-IP rate
# limit on /api/chat to be active. If left blank, the rate limit is a
# no-op (fine for local dev; set these before deploying publicly).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
